---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = await getCollection("posts");
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
---

<Layout>
  <Header />
  <main
    id="main-content"
    data-layout="index"
    data-home-path={homePath}
    class="app-layout"
  >
    <section
      id="hero"
      class="border-border grid gap-10 border-b py-14 sm:py-20 lg:grid-cols-[minmax(0,1fr)_16rem] lg:items-end"
    >
      <div class="min-w-0">
        <div
          class="bg-accent/80 text-accent-foreground mb-10 flex size-36 items-center justify-center rounded-[1.75rem] text-3xl font-semibold sm:size-44"
          aria-hidden="true"
        >
          III
        </div>
        <h1
          class="font-editorial max-w-3xl text-4xl leading-none font-semibold sm:text-6xl lg:text-7xl"
        >
          Hippocampus III
        </h1>
        <p class="mt-8 max-w-full text-xl leading-8 sm:max-w-2xl">
          ??????????????????????????????????????????
        </p>
        <p
          class="text-muted-foreground mt-4 max-w-full text-lg leading-8 sm:max-w-2xl"
        >
          ??????????????????????????????
        </p>
      </div>
      <aside class="border-border border-t pt-6 text-sm lg:border-t-0 lg:pt-0">
        <dl class="space-y-5">
          <div>
            <dt class="text-muted-foreground">Category</dt>
            <dd class="decoration-border mt-1 underline underline-offset-4">
              Notes
            </dd>
          </div>
          <div>
            <dt class="text-muted-foreground">System</dt>
            <dd class="mt-1">External memory</dd>
          </div>
          <div>
            <dt class="text-muted-foreground">Feed</dt>
            <dd class="mt-1">
              <a
                target="_blank"
                href={getRelativeLocaleUrl(locale, "rss.xml")}
                class="decoration-border hover:text-accent inline-flex items-center gap-2 underline underline-offset-4"
                aria-label="RSS Feed"
                title="RSS Feed"
              >
                RSS
                <IconRss class="stroke-accent size-4 stroke-3 rtl:-rotate-90" />
              </a>
            </dd>
          </div>
        </dl>
      </aside>
      {
        socials.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
              {t.home.socialLinks}:
            </div>
            <Socials />
          </div>
        )
      }
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "py-12 sm:py-16",
            { "border-border border-b": recentPosts.length > 0 },
          ]}
        >
          <h2 class="font-editorial text-3xl font-semibold">
            {t.home.featured}
          </h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="py-12 sm:py-16">
          <h2 class="font-editorial text-3xl font-semibold">
            {t.home.recentPosts}
          </h2>
          <ul>
            {recentPosts.slice(0, postsConfig.perIndex).map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    <div class="border-border my-8 border-t pt-8 text-center">
      <LinkButton
        class="decoration-border hover:text-accent underline underline-offset-4"
        href={getRelativeLocaleUrl(locale, "posts")}
      >
        {t.home.allPosts}
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
